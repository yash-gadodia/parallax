{
  "expo": {
    "name": "parallax",
    "slug": "parallax",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "parallax",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.yashgadodia.parallax",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FBF1F2"
      }
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "@bacons/apple-targets",
      "expo-router",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF1F2",
          "image": "./assets/splash-icon.png",
          "imageWidth": 180
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "bundleIdentifier": "com.yashgadodia.parallax",
      "appleTeamId": "P6QG53Y747",
      "usesAppleSignIn": true,
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.yashgadodia.parallax"
        ]
      },
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSSupportsLiveActivities": true
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5404ebf0-ec43-4fa6-80af-c1912b8e9a21"
      }
    },
    "owner": "mcbebu",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5404ebf0-ec43-4fa6-80af-c1912b8e9a21"
    }
  }
}
