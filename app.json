{
  "expo": {
    "name": "parallax",
    "slug": "parallax",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "parallax",
    "userInterfaceStyle": "automatic",
    "android": {
      "predictiveBackGestureEnabled": false,
      "package": "com.yashgadodia.parallax"
    },
    "web": {
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      "expo-web-browser",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#FBF1F2"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "ios": {
      "bundleIdentifier": "com.yashgadodia.parallax",
      "usesAppleSignIn": true,
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "5404ebf0-ec43-4fa6-80af-c1912b8e9a21"
      }
    },
    "owner": "mcbebu",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/5404ebf0-ec43-4fa6-80af-c1912b8e9a21"
    }
  }
}
